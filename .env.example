# ============================================
# EurekaNews — Environment Configuration
# ============================================
# Copy this file to .env and adjust values for your deployment.
#
#   cp .env.example .env

# --------------------------------------------------
# RSSHub
# --------------------------------------------------
# Base URL of your RSSHub instance.
# Local dev: http://localhost:1200 | Server via Tailscale: http://100.x.x.x:1200
RSSHUB_BASE_URL=http://localhost:1200

# --------------------------------------------------
# MongoDB
# --------------------------------------------------
# Connection URI. Must match the credentials in docker-compose.yml.
MONGODB_URL=mongodb://ai_admin:your_strong_password_2026@127.0.0.1:27017
MONGODB_DB_NAME=eureka_news

# --------------------------------------------------
# LLM Provider
# --------------------------------------------------
# Provider type: "ollama" or "openai" (any OpenAI-compatible API)
LLM_PROVIDER=ollama

# Ollama settings (used when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:14b

# OpenAI-compatible settings (used when LLM_PROVIDER=openai)
# Works with OpenAI, DeepSeek, or any compatible endpoint.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# --------------------------------------------------
# Scheduler
# --------------------------------------------------
FETCH_INTERVAL_HOURS=2
