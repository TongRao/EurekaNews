# ============================================
# EurekaNews — Environment Configuration
# ============================================
# Copy this file to .env and adjust values for your deployment.
#
#   cp .env.example .env
#
# The .env file is gitignored and will NOT be committed.

# Base URL of your RSSHub instance.
# - Local dev (RSSHub on same machine):  http://localhost:1200
# - Server via Tailscale:                http://100.x.x.x:1200
# - Docker same-host:                    http://rsshub:1200
RSSHUB_BASE_URL=http://localhost:1200
