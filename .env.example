# ============================================
# EurekaNews — Environment Configuration
# ============================================
# Copy this file to .env and adjust values for your deployment.
#
#   cp .env.example .env

# --------------------------------------------------
# RSSHub
# --------------------------------------------------
# Base URL of your RSSHub instance.
# Local dev: http://localhost:1200 | Server via Tailscale: http://100.x.x.x:1200
RSSHUB_BASE_URL=http://localhost:1200

# --------------------------------------------------
# MongoDB
# --------------------------------------------------
# Database credentials (used by docker-compose to initialize the DB and Mongo-Express)
MONGO_INITDB_ROOT_USERNAME=ai_admin
MONGO_INITDB_ROOT_PASSWORD=your_strong_password_2026

# Application Connection URI
MONGODB_URL=mongodb://${MONGO_INITDB_ROOT_USERNAME}:${MONGO_INITDB_ROOT_PASSWORD}@127.0.0.1:27017
MONGODB_DB_NAME=eureka_news

# --------------------------------------------------
# Mongo-Express Web UI
# --------------------------------------------------
# Login credentials for viewing your database at http://127.0.0.1:8081
MONGO_EXPRESS_USERNAME=admin
MONGO_EXPRESS_PASSWORD=password

# --------------------------------------------------
# LLM Provider
# --------------------------------------------------
# Provider type: "ollama" or "others" (any OpenAI-compatible API)
LLM_PROVIDER=ollama

# Ollama settings (used when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:14b

# Others settings (used when LLM_PROVIDER=others)
# Works with OpenAI, DeepSeek, Kimi, or any compatible endpoint.
OTHERS_API_KEY=
OTHERS_BASE_URL=https://api.openai.com/v1
OTHERS_MODEL=gpt-4o-mini

# --------------------------------------------------
# Telegram Bot
# --------------------------------------------------
# Get your token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather

# --------------------------------------------------
# Scheduler
# --------------------------------------------------
FETCH_INTERVAL_HOURS=2
